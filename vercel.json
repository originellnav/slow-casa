{
  "cleanUrls": true,
  "redirects": [
    { "source": "/property.html", "destination": "/directory", "permanent": true },
    { "source": "/property", "destination": "/directory", "permanent": true },
    { "source": "/journal", "destination": "/guides", "permanent": true },
    { "source": "/journal/:path*", "destination": "/guides", "permanent": true },
    { "source": "/places/:slug", "destination": "/", "statusCode": 410 }
  ],
  "rewrites": [
    { "source": "/directory", "destination": "/api/directory" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/properties/:slug", "destination": "/api/property-page?slug=:slug" },
    { "source": "/design-directory", "destination": "/api/architects-index" },
    { "source": "/architects/:slug", "destination": "/api/architect?slug=:slug" },
    { "source": "/guides", "destination": "/api/guides-index" },
    { "source": "/guides/:slug", "destination": "/api/guide-page?slug=:slug" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/go/:slug", "destination": "/api/go?slug=:slug" }
  ]
}
